Sub btnokmre_Click
Try
DateTime.DateFormat = "yyyy-MM-dd"
Dim Tom As Long
Dim iDay As Int
Dim DaySave As String 
       
		If lblmonthre.Text="- เลือก -" Or lblmonthreend.Text="- เลือก -" Then
			Msgbox("ตรวจสอบวันที่ในการเพิ่มมื้ออาหาร","แจ้งเตือน")
			Return
		End If 
			 		reUpdate="ALL"
					Dim rs As Cursor			'
					Dim sql As String 
					sql="select user_id,repast_date from repastname where user_id='" & idname & "' and repast_date between '" & lblmonthre.Tag &"'  And '" & lblmonthreend.Tag &"' "
					rs=dbSQL.ExecQuery(sql)
					rs.Position=0
						If rs.rowcount > 0 Then
								Dim i As Int
								i = Msgbox2("ในระหว่างวันที่เลือกมีการบันทึกมื้อในวันที่แล้ว ต้องการ 'แก้ไขทับ' หรือ 'ข้าม' มื้ออาหาร", "แจ้งเตือน", "แก้ไข", "", "ข้าม", Null)
						    		If i =-1 Then 			'แก้ไข	
						   				reUpdate="Y"
						    		Else If i= -2  Then 	'ข้าม									
										reUpdate="N"
						   			End If
						End If    									
							              If  reUpdate="Y" Then
											    dbSQL.ExecNonQuery("delete from repastname where user_id='" & idname & "'and repast_date between '" & lblmonthre.Tag &"'  And '" & lblmonthreend.Tag &"'" )
										  End If
										   
											 Do While  DaySave <>  lblmonthreend.Tag  	
											     Tom = DateTime.Add(DateTime.DateParse(lblmonthre.Tag), 0, 0, iDay)
											     DaySave=DateTime.Date(Tom)
														If  reUpdate="ALL" Or  reUpdate="Y"  Then
														    SaveNewALL(DaySave)
														Else 'N ข้ามที่มีข้อมูลแล้ว
														    SaveUpdate(DaySave)
														End If 
															 iDay=iDay+1
											  Loop
				
	
	Msgbox("เพิ่มมื้ออาหารสำเร็จ","แจ้งเตือน")
	Activity.RemoveAllViews
	Activity.LoadLayout("showrepast")
	pnshowre.Visible=True	
	showrepast					
	Catch
	Msgbox(LastException,"x")
	End Try
	
End Sub
