Sub Table_matmenu_CellClick (Col As Int, Row As Int)
		If Col=1 Then
			idmenu = Table1.GetValue(0,Row)
			showmatmenu	
			
			
		else if Col=2 Then
			Dim i As Int
				i = Msgbox2("กรุณาเลือก?", "แจ้งเตือน", "แก้ไข", "", "ลบ", Null)
					If i=-1 Then   'do Yes code
						Dim sql As String 																			'จัดการฐานข้อมูล
					    sql="delete from detailmenu where material_id='" & Table1.GetValue(0,Row) &"'"      'คำสั่งลบข้อมูล ใน-ชื่อตาราง-ตำแหน่งตาราง  
				     	dbSQL.ExecNonQuery(sql)
						Table1.ClearAll
			           	showmatmenu
					Else If i=-2 Then
					   Return
					Else
						Return
					End If
		End If
	Msgbox("ลบข้อมูลสำเร็จ","แจ้งเตือน")
End Sub

