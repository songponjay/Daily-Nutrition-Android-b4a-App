Sub showfoodtype
        Activity.RemoveAllViews
		Activity.LoadLayout("foodtype")
																	  	    '{สร้างตาราง
		          Table1.Initialize(Me, "Table_type", 4)  				    'เรียกตารางจากไลเบอรี่ สร้าง4คอลลัม 	table_type ตั้งชื่อเหตุการณ์
				  Table1.AddToActivity(Activity, 0,btnshowtype.Top + btnshowtype.Height ,100%x,100%y - btnshowtype.Height)	'กำหนดตำแหน่งของตาราง ,ชิดซ้าย,ตำแหน่งบน,ความกว้าง,ความสูงลบปุ่ม
				  Table1.SetHeader(Array As String("id","ชื่อประเภท","รายการ","แก้ไข"))		 'เพิ่มคำในหัวตารางตามคอมม่า
				  Table1.SetColumnsWidths(Array As Int(0%x,65%x, 20%x,15%x)) 					 'กำหนดความกว้างของแต่ละช่อง							}สร้างตาราง มีต่อ				
  Dim rs As Cursor
  Dim sql As String 
'  select foodtype.type_name,foodtype.type_id,count(material.type_id) as total from foodtype inner join material on foodtype.type_id=material.type_id group by foodtype.type_name,foodtype.type_id
  sql="select foodtype.type_name,foodtype.type_id,count(material.type_id) as total from foodtype left join material on foodtype.type_id=material.type_id group by foodtype.type_name,foodtype.type_id "
  rs=dbSQL.ExecQuery(sql)						'เรียกข้อมูลในฐานมาโชว์
  Table1.ClearAll
  For i = 0 To rs.RowCount -1
     rs.Position =i
	   Table1.AddRow(Array As String(rs.GetString("type_id") , rs.GetString("type_name") , rs.GetString("total") , "..." )) 'เรียกฐานข้อมูลมาแสดงในตาราง   				}สร้างตาราง ต่อ
  Next 
End Sub 

Sub Table_type_CellClick (Col As Int, Row As Int) 									'เหตุการณ์แตะในตาราง												}สร้างตาราง ต่อ
	If Col=1 Then
		idtype= Table1.GetValue(0,Row)
		showMaterial
	else  If Col=3 Then
				idtype= Table1.GetValue(0,Row)
		        Dim i As Int
				i = Msgbox2("กรุณาเลือก?", "แจ้งเตือน", "แก้ไข", "", "ลบ", Null)
					If i=-1 Then
					    dataMode="edit" 'เก็บค่า edit 
						Activity.RemoveAllViews
						Activity.LoadLayout("foodtype_new")
							Dim rs As Cursor
							Dim sql As String 
								sql="select type_name from foodtype  where type_id='" & idtype & "'"			'เรียกเมนูจากฐานข้อมูลมาแสดง
								rs=dbSQL.ExecQuery(sql)
								rs.Position =0
							    txtfoodtype.Text = rs.GetString("type_name")
	               Else If i=-2 Then
					   Dim sql As String 																			'จัดการฐานข้อมูล
					    sql="delete from foodtype where type_id='" &  idtype  & "'"      'คำสั่งลบข้อมูล ใน-ชื่อตาราง-ฟิว  
				     	dbSQL.ExecNonQuery(sql)			'ลบฐานข้อมูล,อัพเดท,เพิ่มเข้า
					   Activity.RemoveAllViews
			           Activity.LoadLayout("foodtype")
					   showfoodtype
					Else
					 	Return
			        End If 
	    
	End If
End Sub 

