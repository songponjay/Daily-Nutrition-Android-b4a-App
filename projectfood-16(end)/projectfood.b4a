Sub btncalmenu_Click 'eatเพิ่มเมนูในมื้ออาหาร
Try
	Activity.RemoveAllViews
	Activity.LoadLayout("eat")
			Spshowdate.Add("")
			  Dim rs As Cursor
  			  Dim sql As String 
			  sql="select repast_date from repastname where user_id='"& idname &"' group by repast_date order by repast_date "
			  rs=dbSQL.ExecQuery(sql)
			  	For i = 0 To rs.RowCount -1
			     rs.Position =i
				 
				        Dim sp() As String
							sp=Regex.Split("\-",rs.GetString("repast_date"))
				 
				 	Spshowdate.Add((sp(2) & "/" & sp(1) & "/" & sp(0)))
					
				Next 
Catch
Msgbox(LastException,"x")
End Try
			
End Sub

