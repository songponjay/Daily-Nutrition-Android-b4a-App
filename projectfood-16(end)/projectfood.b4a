Sub btndiet_Click
	Activity.RemoveAllViews
	Activity.LoadLayout("nutrient")
	Activity.SetBackgroundImage (LoadBitmap(File.DirAssets, "new-im2-1.jpg")) 
	
	
		spselectday.Add("")
	
		  Dim rs As Cursor
		  Dim sql As String 
		  sql="select repast_date from repastname where user_id='"& idname &"' group by repast_date order by repast_date "
		  rs=dbSQL.ExecQuery(sql)
		  	For i = 0 To rs.RowCount -1
		     rs.Position =i
			 
			        Dim sp() As String
						sp=Regex.Split("\-",rs.GetString("repast_date"))
			 			spselectday.Add((sp(2) & "/" & sp(1) & "/" & sp(0)))
				
			Next 
			
			
			spselectday2.Add("")
			  Dim rs As Cursor
  			  Dim sql As String 
			  sql="select repast_date from repastname where user_id='"& idname &"' group by repast_date order by repast_date "
			  rs=dbSQL.ExecQuery(sql)
			  	For i = 0 To rs.RowCount -1
			     rs.Position =i
				 
				        Dim sp() As String
							sp=Regex.Split("\-",rs.GetString("repast_date"))
							spselectday2.Add((sp(2) & "/" & sp(1) & "/" & sp(0)))
			Next 
		
End Sub

