Sub test_Click		'ปุ่มไว้ดูฐานข้อมูล 
	If	Pnre.Visible=True Then
	Pnre.Visible=False
	Table1.ClearAll
	Activity.RemoveAllViews
	Activity.LoadLayout("mng_repast")
			Dim rs As Cursor
			Dim sql As String 
				sql="select namesuser,user_id from recorduser"			'เรียกเมนูจากฐานข้อมูลมาแสดง
				rs=dbSQL.ExecQuery(sql)
				rs.Position =0
  			    lblidname.Text = rs.GetInt("user_id")
				lblnamere.Text = rs.GetString("namesuser")
	
	Else If Pnre.Visible=False Then
		  Table1.Initialize(Me, "Table_test", 5)  
		  Table1.AddToActivity(Activity, 0,lblrepast.Top + lblrepast.Height ,100%x,100%y - lblrepast.Height)
		  Table1.SetHeader(Array As String("id","ชื่อมื้อ","วันที่","จำนวน","ชื่อผู้เพิ่มไปแล้ว"))		
		  Table1.SetColumnsWidths(Array As Int(5%x,35%x,20%x,20%x,20%x)) 								
		  Dim rs As Cursor
		  Dim sql As String 
		  sql="select repastname_id,repastname_name,repast_date,repast_count,user_id from repastname order by repast_date"
		  rs=dbSQL.ExecQuery(sql)
		  		For i = 0 To rs.RowCount -1
		   	    rs.Position =i
			    Table1.AddRow(Array As String(rs.GetString("repastname_id") , rs.GetString("repastname_name") , rs.GetString("repast_date") ,rs.GetString("repast_count"),rs.GetString("user_id")))
				Next 
			Pnre.Visible=True
	End If
End Sub

