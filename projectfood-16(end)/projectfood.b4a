Sub showmenu
			  Table1.Initialize(Me, "Table_menu",6)  		'7		    
			  Table1.AddToActivity(Activity, 0,btnaddmenu.Top + btnaddmenu.Height ,100%x,100%y - btnaddmenu.Height)	
			  Table1.SetHeader(Array As String("id","ชื่อเมนู","Prot","crab","fat","แก้ไข"))		 ',"เลือกแล้ว"
			  Table1.SetColumnsWidths(Array As Int(0,50%x,12.5%x,12.5%x,12.5%x,12.5%x)) 			',15%x					
				  Dim rs As Cursor
				  Dim sql As String 
				  sql="select menufood_id,menufood_name from menufood"
'				  sql="select foodtype.type_name,foodtype.type_id,count(material.type_id) as total from foodtype left join material on foodtype.type_id=material.type_id group by foodtype.type_name,foodtype.type_id "
'				  sql="select prot,crab,fat from material inner join detailmenu on detailmenu.material_id=material.material_id "
				  rs=dbSQL.ExecQuery(sql)						'เรียกข้อมูลในฐาน

				  For i = 0 To rs.RowCount -1
				     rs.Position =i
					   Table1.AddRow(Array As String(rs.GetString("menufood_id") , rs.GetString("menufood_name") ,getProt(rs.GetString("menufood_id")),getCrab(rs.GetString("menufood_id")),getFat(rs.GetString("menufood_id")),"..." )) 'เรียกฐานข้อมูลมาแสดงในตาราง   			rs.GetString("prot"),rs.GetString("crab"),rs.GetString("fat")
				  Next 
				  
End Sub

Sub getProt(idFood As Double)					'โปรตีน
    Dim ss As String 
	Dim rs As Cursor
	ss="select sum(material.prot * material_amount) as totalG from material inner join detailmenu on material.material_id = detailmenu.material_id "
	ss=ss & " where detailmenu.menufood_id = '" & idFood & "' "
	rs=dbSQL.ExecQuery(ss)
		If rs.RowCount >0 Then 
			rs.Position=0
			   If rs.GetString("totalG") =Null Then
			     Return "" 									
			   Else 
			     Return rs.GetString("totalG") 
			   End If 
		Else
			Return ""
		End If 
End Sub 

Sub getCrab(idFood As Double)					'คาร์โบในเมน
   Dim ss As String 
	Dim rs As Cursor
	ss="select sum(material.crab * material_amount) as totalG from material inner join detailmenu on material.material_id = detailmenu.material_id "
	ss=ss & " where detailmenu.menufood_id = '" & idFood & "' "
	rs=dbSQL.ExecQuery(ss)
	
	If rs.RowCount >0 Then 
	rs.Position=0
	   If rs.GetString("totalG") =Null Then
	     Return "" 				
	   Else 
	     Return rs.GetString("totalG") 
	   End If 
	Else
	   Return ""
	End If 
End Sub 

Sub getFat(idFood As Double)					'ไว้ทำเพิ่ม ไขมัน-*-*-*-*-	'fatในเมนู
    Dim ss As String 
	Dim rs As Cursor
	ss="select sum(material.fat * material_amount) as totalG from material inner join detailmenu on material.material_id = detailmenu.material_id "
	ss=ss & " where detailmenu.menufood_id = '" & idFood & "' "
	rs=dbSQL.ExecQuery(ss)
	
	If rs.RowCount >0 Then 
	rs.Position=0
	   If rs.GetString("totalG") =Null Then
	     Return "" 									
	   Else 
	     Return rs.GetString("totalG") 
	   End If 
	Else
	   Return ""
	End If 
End Sub 

Sub Table_menu_CellClick (Col As Int, Row As Int) 									


		If Col=1 Then
			Dim i As Int
			i = Msgbox2("ยืนยันการแก้ไขข้อมูล", "แจ้งเตือน", "แก้ไข", "", "ยกเลิก", Null)
				If i =-1 Then 'แก้ไข
					
				Else If i= -2  Then 'ยกเลิก
					Return
				Else
						Return
				End If
		Else If Col=5 Then
			idmenu= Table1.GetValue(0,Row)

			Activity.RemoveAllViews
			Activity.LoadLayout("mng_menu")	
			showmatmenu
			
			Dim rs As Cursor
