			 		sql=sql & " sum(material.crab * detailmenu.material_amount * takefood.takefood_count) As crab,"	
					sql=sql & " sum(material.fiber * detailmenu.material_amount * takefood.takefood_count) As fiber,"
					sql=sql & " sum(material.fat * detailmenu.material_amount * takefood.takefood_count) As fat,"
					sql=sql & " sum(material.iron * detailmenu.material_amount * takefood.takefood_count) As iron,"
					sql=sql & " sum(material.chol * detailmenu.material_amount * takefood.takefood_count) As chol,"
