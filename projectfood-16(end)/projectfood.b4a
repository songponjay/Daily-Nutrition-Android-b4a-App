Sub lvname_ItemLongClick (Position As Int, Value As Object)
		Try
		Dim i As Int 
		i = Msgbox2("กรุณาเลือก?", "แจ้งเตือน", "แก้ไข", "", "ลบ", Null)
		
					If i=-1 Then   'do Yes code
						Activity.RemoveAllViews
						Activity.LoadLayout("showname_new")
						dataMode="edit"
						Dim sql As String
						Dim rs As Cursor
						sql="select namesuser,birthday,whight,hight,usernick,sex from recorduser where user_id='"&Value&"'"
						rs = dbSQL.ExecQuery(sql)
						rs.Position=0
						txtname.Text = rs.GetString("namesuser")
						lblhbd.Text = rs.GetString("birthday")
							Dim sp() As String
							sp=Regex.Split("\-",lblhbd.Text)
							lblhbd.Text = sp(2) &"/"& sp(1) &"/"& sp(0)
									txtwhight.Text = rs.GetInt("whight")		'weight
									txtheight.Text = rs.GetInt("hight")		'height
									txtnickname.Text = rs.GetString("usernick")
										If rs.GetString("sex") =("ชาย") Then
							  				RadioM.Checked =True
										Else If rs.GetString("sex") =("หญิง") Then
											RadioW.Checked =True
										End If
					Else If i=-3 Then				  
								Dim sql As String
								sql="delete from recorduser where user_id='"&Value&"'"
								dbSQL.ExecNonQuery(sql)
								
								lvname.Clear
								showname
					Else
								Return
					End If
		Catch
		Msgbox(LastException,"x") 
   		End Try 
End Sub

