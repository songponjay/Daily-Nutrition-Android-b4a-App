Sub btnsavetype_Click
	Try
	
			If txtfoodtype.text="" Then
			Msgbox("โปรดใส่ชื่อประเภทอาหาร","แจ้งเตือน")
			txtfoodtype.RequestFocus
			Return
			End If
				Dim rs As Cursor		'ค้นหา ชื่อซ้ำ ว่ามีหรือไม่ในฐานข้อมูล
				Dim sql As String 
				sql="select type_name from foodtype where type_name='" & txtfoodtype.text & "'"
				rs=dbSQL.ExecQuery(sql)
				  	If rs.RowCount>0 Then
						Msgbox("มีรายชื่อนี้แล้วในระบบ","แจ้งเตือน")
						Return
					End If
						Dim sqlfood As String
							If dataMode="new"  Then 'ถ้าตัวแปรเป็น new หมายถึงกดปุ่มเพิ่มมา ให้ insert 
									sqlfood="insert into foodtype("
									sqlfood=sqlfood & " type_name" '1
									sqlfood=sqlfood & " )values("
									sqlfood=sqlfood & " '"&txtfoodtype.text&"'" '1
									sqlfood=sqlfood & " )"
							Else 'ถ้า datamode ไม่ใช่ new หมายถึงมาจากากรแก้ไข
							        sqlfood="update   foodtype set "
									sqlfood=sqlfood & " type_name= '"&txtfoodtype.text&"' " '1
									sqlfood=sqlfood & " where type_id='" & idtype & "' "
							End If 
					        	dbSQL.ExecNonQuery(sqlfood) 
								Msgbox("บันทึกชื่อประเภทสำเร็จ","แจ้งเตือน")
				 				showfoodtype

					
	Catch
	Msgbox(LastException,"x")
	End Try
End Sub

