Sub lblhbd_Click 
    Dim ret As Int 
	Dim Dd As DateDialog													'เลือกวันเกิด
	Dd.Year = DateTime.GetYear(DateTime.Now)
	Dd.Month = DateTime.GetMonth(DateTime.Now)	
	Dd.DayOfMonth = DateTime.GetDayOfMonth(DateTime.Now)
	ret = Dd.Show("Set the required date", "B4A Date Dialog", "No", "Yes", "", Null)
	If ret=-1 Then
			lblhbd.text = Dd.DayOfMonth & "/" & Dd.Month & "/" & Dd.Year 
			lblhbd.tag =  Dd.Year & "-" & Dd.Month & "-" & Dd.DayOfMonth			'2020-03-31
	Else If ret=-3 Then
		Return
	End If
End Sub

