Sub nameeat
          	lvfoodinday.Clear
			  Dim rs As Cursor
			  Dim sql As String
			  sql="select takefood.repastname_id,takefood.takefood_count,menufood.menufood_id,menufood.menufood_name from takefood "
			  sql=sql & " inner join menufood on takefood.menufood_id = menufood.menufood_id "
			  sql=sql & " where takefood.repastname_id='" & eatid & "'"
			  rs=dbSQL.ExecQuery(sql)
			  For i = 0 To rs.RowCount -1
			     rs.Position =i
				 lvfoodinday.AddSingleLine2(rs.GetString("menufood_name"),rs.GetString("repastname_id"))
			  Next
End Sub

