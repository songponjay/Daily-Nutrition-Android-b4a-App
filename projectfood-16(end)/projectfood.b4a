Sub btnuser_Click											'dddddddddddddddddddddddddddddddddddddddดู

	Dim i As Int
	i = Msgbox2("ยืนยันการแก้ไขข้อมูล", "แจ้งเตือน", "แก้ไข", "", "ยกเลิก", Null)
		If i =-1 Then 'แก้ไข
			
		Else If i= -2  Then 'ยกเลิก
			Return
		Else
			Return
		End If
	Activity.RemoveAllViews
	Activity.LoadLayout("showname_new")
		dataMode="Edit"	
			Dim rs As Cursor
			Dim sql As String 
				sql="SELECT user_id,usernick,birthday,sex,namesuser,whight,hight FROM recorduser where user_id='" & idname & "'"			'เรียกเมนูจากฐานข้อมูลมาแสดง
				rs=dbSQL.ExecQuery(sql)
				rs.Position = 0
			    txtname.text = rs.GetString("namesuser")
				lblhbd.text = rs.GetString("birthday")
'		Msgbox(lblhbd.Text,"xx") 'เช็ควันที่
					Dim sp() As String
					sp=Regex.Split("\-",lblhbd.Text)
					lblhbd.Text = sp(2) &"/"& sp(1) &"/" & sp(0)
				txtwhight.text = rs.GetString("whight")
				txtheight.text = rs.GetString("hight")
				txtnickname.text = rs.GetString("usernick")
					If rs.GetString("sex") =("ชาย") Then
						RadioM.Checked =True
					Else If rs.GetString("sex") =("หญิง") Then
						RadioW.Checked =True
					End If
								
			
	
End Sub

