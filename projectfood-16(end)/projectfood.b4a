Sub showselectmat
			lvmatmenu.Clear 
			  Dim rs As Cursor
			  Dim sql As String 
			  sql="select material_id, material_name from material"
			  sql=sql & " where material_id not in( select material_id from  detailmenu where  menufood_id='" & idmenu & "' )"
			  rs=dbSQL.ExecQuery(sql)
			  For i = 0 To rs.RowCount -1
			     rs.Position =i
				 lvmatmenu.AddSingleLine2(rs.GetString("material_name"),rs.GetString("material_id"))
			 Next
End Sub

Sub lvmatmenu_itemClick(Position As Int,Value As Object)
			  Dim rs As Cursor
			  Dim sql As String 
		  	  sql="select material_name,material_id from material where material_id='"& Value &"'"
			  rs=dbSQL.ExecQuery(sql)
			  rs.Position = 0
			 txtmenup1.Text = Value
			 txtmenup2.Text = rs.GetString("material_name")
End Sub

