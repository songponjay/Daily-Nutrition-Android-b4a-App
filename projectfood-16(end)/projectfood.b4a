								sql="select material_name,kcal,prot,vitA,vitC,vitE,vitB1,vitB2,vitB3,vitB6,vitB12,chol,sodi,pota,calc,magn,iron,zinc,sele,crab,fat,h2o,fiber,vitB9 from material where material_id='" & idmat & "' "			'เรียกเมนูจากฐานข้อมูลมาแสดง
								rs=dbSQL.ExecQuery(sql)
								rs.Position =0
							    txtmate1.text = rs.GetString("material_name")
'	เพิ่มสารอาหาร							
'								txtmate2.Text = rs.GetString("") 'ต้องต่อ1กรัมเท่านั้น
								txtmate3.Text = rs.GetString("kcal")
								txtmate4.Text = rs.GetString("prot")
								txtmate5.Text = rs.GetString("vitA")
								txtmate6.Text = rs.GetString("vitC")
								txtmate7.Text = rs.GetString("vitE")
								txtmate8.Text = rs.GetString("vitB1")
								txtmate9.Text = rs.GetString("vitB2")
								txtmate10.Text = rs.GetString("vitB3")
								txtmate11.Text = rs.GetString("vitB6")
								txtmate12.Text = rs.GetString("vitB12")
								txtmate13.Text = rs.GetString("chol")
								txtmate14.Text = rs.GetString("sodi")
								txtmate15.Text = rs.GetString("pota")
								txtmate16.Text = rs.GetString("calc")
								txtmate17.Text = rs.GetString("magn")
								txtmate18.Text = rs.GetString("iron")
								txtmate19.Text = rs.GetString("zinc")
								txtmate20.Text = rs.GetString("sele")
								txtmate21.Text = rs.GetString("crab")
