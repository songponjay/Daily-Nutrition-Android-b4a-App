Sub Activity_Create(FirstTime As Boolean)
	'Do not forget to load the layout file created with the visual designer. For example:
	
	If FirstTime =True Then				
 		If File.Exists(File.DirInternal,"food.db") = False Then
			File.Copy(File.DirAssets,"food.db",File.DirInternal,"food.db")
		End If
	End If 
		If dbSQL.IsInitialized = False Then 
			dbSQL.Initialize(File.DirInternal, "food.db", True) 'DirInternal 'DirDefaultExternal
		End If
		
	Activity.LoadLayout("showname")
  	showname
End Sub

Sub showname
lvname.Height=100%y-(btnnewname.height)
lvname.Width=100%x

  Dim rs As Cursor
  Dim sql As String 
  sql="select user_id,namesuser from recorduser"					'เรียกsqlในฟิวrec user 111
  rs=dbSQL.ExecQuery(sql)
	  For i = 0 To rs.RowCount -1
	     rs.Position =i
		 lvname.AddSingleLine2(rs.GetString("namesuser"),rs.GetString("user_id"))
	  Next   	
	  
	
End Sub 

Sub lvname_ItemClick (Position As Int, Value As Object)
		Activity.RemoveAllViews
		idname = Value
		idname1 = Value
		Activity.LoadLayout("home")
		
'	  	agecal
'		sexcal
			 Dim rs As Cursor
			 Dim sql As String 
		  sql="select sex,birthday,user_id,namesuser,julianday('now') - julianday(birthday) as days from recorduser"					'เรียกsqlในฟิวrec user 111
		  rs=dbSQL.ExecQuery(sql)
		  rs.Position = 0
		  	agecal = rs.GetString("days")/365
			
			If agecal <=8 Then 
			   sexcal="ร"
			Else
			  If rs.GetString("sex")="ชาย" Then
			       sexcal = "ช"
				   Else
				   sexcal = "ญ"
			  End If 
			End If	

End Sub

