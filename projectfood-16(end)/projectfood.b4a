	End If 
End Sub

Sub spselectday_ItemClick (Position As Int, Value As Object)
Try
	Dim sp() As String
	sp=Regex.Split("\/",Value)
	
	idnutri = sp(2) &"-"&sp(1)&"-"&sp(0)
	lblselectday.tag = idnutri
'	Msgbox(Value,Position)

			
	Catch
	Msgbox(LastException,"x")
	End Try
End Sub

Sub spselectday2_ItemClick (Position As Int, Value As Object)
