Sub showmatmenu				'วัตถุดิบในเมนู		
  Table1.Initialize(Me, "Table_matmenu", 3)
  Table1.AddToActivity(Activity,0,btnaddmatmenu.Top + btnaddmatmenu.Height ,100%x,100%y - btnaddmatmenu.Height)
  Table1.SetHeader(Array As String("id","ชื่อวัตถุดิบ","ปริมาณ(กรัม)"))		
  Table1.SetColumnsWidths(Array As Int(0,60%x,40%x)) 
  Dim rs As Cursor
  Dim sql As String 
		  sql="select detailmenu.material_amount,"
		  sql=sql & "  detailmenu.material_id,"
		  sql=sql & "  material.material_name, "
		  sql=sql & "  detailmenu.menufood_id from detailmenu "
		  sql=sql & "  inner join material on material.material_id=detailmenu.material_id "
		  sql=sql & " where menufood_id='"& idmenu & "'"
		  
		  rs=dbSQL.ExecQuery(sql)
		  Table1.ClearAll
		  	For i = 0 To rs.RowCount -1
		     rs.Position =i
			   Table1.AddRow(Array As String(rs.GetString("material_id"), rs.GetString("material_name") , rs.GetString("material_amount")))
			   
			Next 		
End Sub
