		  Table1.AddToActivity(pneat,0,0,100%y,100%x-btnconeat.Height)
		  Table1.SetHeader(Array As String("id","ชื่อเมนู","เลือก","จำนวน"))	
		  Table1.SetColumnsWidths(Array As Int(0,65%x,20%x,15%x)) 	
				  Dim rs As Cursor
				  Dim sql As String 
				  sql="select menufood_id,menufood_name from menufood"
				  rs=dbSQL.ExecQuery(sql)		
				  For i = 0 To rs.RowCount -1
				     rs.Position =i
					   Table1.AddRow(Array As String(rs.GetInt("menufood_id") , rs.GetString("menufood_name"),("..."),("1"))) 'เรียกฐานข้อมูลมาแสดงในตาราง   ', "","","","","..."
				  Next 
				  TotalRows=i
End Sub

Sub Table_eat_CellClick (Col As Int, Row As Int) 
	If Col =2 Then
	   If Table1.GetValue(2,Row)="..." Then
	   		Table1.SetValue(2,Row,"X")
												'0000000000000000000000000000
									    Dim Id As InputDialog
										Dim ret As Int
											Id.Input = Table1.GetValue(3,Row)
											Id.Hint = ""
											Id.InputType =Id.INPUT_TYPE_DECIMAL_NUMBERS 
											Id.HintColor = Colors.ARGB(196, 255, 140, 0)
											ret = DialogResponse.CANCEL
											ret = Id.Show("จำนวนจาน","แจ้งเตือน", "ยกเลิก", "", "ตกลง", Null)
											If ret=-3 Then 
											    Return
											Else
										       Table1.SetValue(3,Row,Id.Input)
											End If 
										'=====================================================
	   Else
	   		Table1.SetValue(2,Row,"...")
	   End If 
	   
	End If 
End Sub

