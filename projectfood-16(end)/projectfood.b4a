Sub btncopyrepast_Click 
	Try
		Dim i As Int
		If pnshowre.Visible=False Then
			pnshowre.Top =lblshowreintro1.Top + lblshowreintro1.Height
			pnshowre.Height =100%y 
			pnshowre.Width =100%x 
			pnshowre.Visible=True		
			pnshowre.BringToFront 
'			btncopyrepast.Visible=False
'			btncopyrepast.Enabled=False
				 showcopynamedate
				 i = Msgbox2("ต้องการคัดลอกมื้ออาหารหรือไม่","แจ้งเตือน","ยกเลิกกลับหน้าก่อน","","ใช่",Null)
										If i = -1 Then
											Table1.ClearAll
											pnshowre.Visible=False	
											Return
										Else If i=-2 Then
											Return
										Else
											Return
										End If	
				  
		  Else If pnshowre.Visible=True Then
		  	pnshowre.Visible=False
'			btncopyrepast.Visible=True
'			btncopyrepast.Enabled=True
			showrepast

			End If
	Catch
	Msgbox(LastException,"x")
	End Try
End Sub

