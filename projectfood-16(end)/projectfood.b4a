Sub lblmonthre_Click
	Dim ret As Int 
	Dim Dd As DateDialog													'เลือกวันหน้าจัดการมื้อ
	Dd.Year = DateTime.GetYear(DateTime.Now)
	Dd.Month = DateTime.GetMonth(DateTime.Now)	
	Dd.DayOfMonth = DateTime.GetDayOfMonth(DateTime.Now)
	ret = Dd.Show("แตะเพื่อเลือกวันที่", "ต้้งค่ามื้ออาหาร","No","Yes", "", Null)
		If ret=-3 Then
				lblmonthre.text = Dd.DayOfMonth & "/" & Dd.Month & "/" & Dd.Year 
				Dim a As String 
				Dim b As String 
				a=Dd.Month 
				b=Dd.DayOfMonth
				If a.Length =1 Then a="0" & a
				If b.Length=1 Then b="0" & b
				lblmonthre.tag =  Dd.Year & "-" & a & "-" & b
		Else
			Return
		End If
	
End Sub
Sub lblmonthreend_Click			'เลือกวันหน้าจัดการมื้อ
	Dim set As Int 
	Dim Dd As DateDialog													'เลือกวันหน้าจัดการมื้อ
	Dd.Year = DateTime.GetYear(DateTime.Now)
	Dd.Month = DateTime.GetMonth(DateTime.Now)	
	Dd.DayOfMonth = DateTime.GetDayOfMonth(DateTime.Now)
	set = Dd.Show("แตะเพื่อเลือกวันที่", "ต้้งค่ามื้ออาหาร", "No" , "Yes" , "" , Null)
	If set=-3 Then
				lblmonthreend.text = Dd.DayOfMonth & "/" & Dd.Month & "/" & Dd.Year 
				Dim a As String 
				Dim b As String 
				a=Dd.Month 
				b=Dd.DayOfMonth
				If a.Length =1 Then a="0" & a
				If b.Length=1 Then b="0" & b
				lblmonthreend.tag =  Dd.Year & "-" & a & "-" & b	
	Else
			Return
	End If
						 '  Msgbox("กดที่ปุ่ม'วันที่'เพื่อเลือกอีกครั้ง","วันที่ได้เคยถูกเลือกไปแล้ว")
