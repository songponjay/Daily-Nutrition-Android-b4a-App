'					
'					
'					Return
'				Else If rs.RowCount<0 Then
'								  Dim rs As Cursor		'ค้นหา ชื่อซ้ำ ว่ามีหรือไม่ในฐานข้อมูล
'								  Dim sql As String 
'								  sql="DROP VIEW FoodNutrient"
'								  rs=dbSQL.ExecQuery(sql)
'								  Return
'				End If

 
		  
		  
		  Table1.Initialize(Me, "Table_nutri", 4)   
		  Table1.AddToActivity(Activity,0 ,lblnu2.Top + btncondate.Height,100%x,80%y - btncondate.Height)
		  Table1.SetHeader(Array As String("โภชนาการ","ได้รับ","มาตรฐาน","ผลลัพธ์"))	
		  Table1.SetColumnsWidths(Array As Int(23%x,23%x,24%x,30%x)) 	
				  Dim rs As Cursor
				  Dim sql As String 
			 		sql= "SELECT "
					sql=sql & " sum(material.kcal * detailmenu.material_amount * takefood.takefood_count) As kcal,"
					sql=sql & " sum(material.prot * detailmenu.material_amount * takefood.takefood_count) As prot,"
			 		sql=sql & " sum(material.crab * detailmenu.material_amount * takefood.takefood_count) As crab,"	
					sql=sql & " sum(material.fiber * detailmenu.material_amount * takefood.takefood_count) As fiber,"
					sql=sql & " sum(material.fat * detailmenu.material_amount * takefood.takefood_count) As fat,"
					sql=sql & " sum(material.iron * detailmenu.material_amount * takefood.takefood_count) As iron,"
					sql=sql & " sum(material.chol * detailmenu.material_amount * takefood.takefood_count) As chol,"
					sql=sql & " sum(material.calc * detailmenu.material_amount * takefood.takefood_count) As calc,"
					sql=sql & " sum(material.magn * detailmenu.material_amount * takefood.takefood_count) As magn,"
					sql=sql & " sum(material.pota * detailmenu.material_amount * takefood.takefood_count) As pota,"
					sql=sql & " sum(material.sodi * detailmenu.material_amount * takefood.takefood_count) As sodi,"
					sql=sql & " sum(material.zinc * detailmenu.material_amount * takefood.takefood_count) As zinc,"
					sql=sql & " sum(material.vitA * detailmenu.material_amount * takefood.takefood_count) As vitA,"
					sql=sql & " sum(material.vitB1 * detailmenu.material_amount * takefood.takefood_count) As vitB1,"
					sql=sql & " sum(material.vitE * detailmenu.material_amount * takefood.takefood_count) As vitE,"
					sql=sql & " sum(material.vitB2 * detailmenu.material_amount * takefood.takefood_count) As vitB2,"
					sql=sql & " sum(material.vitB3 * detailmenu.material_amount * takefood.takefood_count) As vitB3,"
					sql=sql & " sum(material.vitB6 * detailmenu.material_amount * takefood.takefood_count) As vitB6,"
'					sql=sql & " sum(material.vitB9 * detailmenu.material_amount * takefood.takefood_count) As vitB9,"
					sql=sql & " sum(material.vitC * detailmenu.material_amount * takefood.takefood_count) As vitC,"
					sql=sql & " sum(material.vitB12 * detailmenu.material_amount * takefood.takefood_count) As vitB12,"
					sql=sql & " sum(material.sele * detailmenu.material_amount * takefood.takefood_count) As sele,"
					
					sql=sql & " julianday('" & lblselectday1.tag &"') - julianday('" & lblselectday.tag & "') +1 as days "
					
					sql=sql & " FROM menufood INNER JOIN detailmenu on detailmenu.menufood_id=menufood.menufood_id"
 					sql=sql & " INNER JOIN material on material.material_id = detailmenu.material_id"
					sql=sql & " INNER JOIN takefood on takefood.menufood_id = detailmenu.menufood_id INNER JOIN repastname on repastname.repastname_id = takefood.repastname_id"			
					sql=sql & " WHERE repast_date between '" & lblselectday.tag & "' and '" & lblselectday1.tag & "' AND user_id = '" & idname & "'"	

								If lblselectday.tag = "" Or lblselectday1.tag= "" Then
									Msgbox("แจ้งเตือน","กรุณาเลือกวันที่")
									Return
								Else
								End If
				Dim x1 As Double 
				Dim x2 As Double
				Dim days As Int 
				  rs=dbSQL.ExecQuery(sql)		
				  For i = 0 To rs.ColumnCount -2
				     rs.Position =0
					  days= rs.GetString("days")
					  
					 x1 = getdri("thdri_" & rs.GetColumnName(i)) * days 
					 x2 = rs.GetString2(i) -  x1
					
					   Table1.AddRow(Array As String(rs.GetColumnName(i) ,rs.GetString2(i),NumberFormat2(x1 ,1,2,2,True),NumberFormat2(x2,1,2,2,True))) 'เรียกฐานข้อมูลมาแสดงในตาราง   
				  Next 
				  TotalRows=i
End Sub

Sub getdri(dri As String) As String

	 	Dim ss As String 
		Dim rs As Cursor
		ss="select  " & dri &" from dri where sex_DRI='" & sexcal & "' And age_start <= '" & agecal & "' and age_end >= '" & agecal & "'"
		rs=dbSQL.ExecQuery(ss)
		If rs.RowCount >0 Then 
			rs.Position=0
			 Return  rs.GetString2(0) 		
			 Else
			 Return ""
		End If 
End Sub

