Sub btngoshowname_Click
	If dataMode="new" Then
			Activity.RemoveAllViews
			Activity.LoadLayout("showname")
			showname
	Else if dataMode="Edit" Then
			Activity.RemoveAllViews
			Activity.LoadLayout("home")
	Else
			Activity.RemoveAllViews
			Activity.LoadLayout("showname")
			showname
	End If
	
End Sub



Sub btnmnmaterial_Click			'โชว์วัตถุดิบทั้งหมด
	Activity.RemoveAllViews
	Activity.LoadLayout("material")									 
		          Table1.Initialize(Me, "Table_material", 6)  	
				  Table1.AddToActivity(Activity, 0,btnaddfood.Top + btnaddfood.Height ,100%x,100%y - btnaddfood.Height)
				  Table1.SetHeader(Array As String("id","ชื่อวัตถุดิบ","โปรตีน","คาร์โบไฮเดรต","ไขมัน","..."))		
				  Table1.SetColumnsWidths(Array As Int(0%x,45%x,15%x,15%x,15%x,10%x)) 								
  Dim rs As Cursor
  Dim sql As String 
  sql="select crab,fat,prot,material_name,material_id from material"
  rs=dbSQL.ExecQuery(sql)
  Table1.ClearAll
  		For i = 0 To rs.RowCount -1
   	    rs.Position =i
	    Table1.AddRow(Array As String(rs.GetString("material_id") , rs.GetString("material_name") , rs.GetString("prot") ,rs.GetString("crab"),rs.GetString("fat"), "..." ))
	Next 		
'type_id,material_name,number,h2o,kcal,prot,crab,fiber,fat,chol,calc,iron,magn,pota,sodi,zinc,vitA,vitB1,vitE,vitB2,vitB3,vitB6,vitB9,vitC,vitB12,sele
		
End Sub

