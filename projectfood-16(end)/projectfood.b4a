					sql=sql & " INNER JOIN takefood on takefood.menufood_id = detailmenu.menufood_id "
					sql=sql & " INNER JOIN repastname on repastname.repastname_id = takefood.repastname_id"			
					sql=sql & " WHERE repast_date = '" & idrepast & "' AND user_id = '" & idname & "' and repastname.repastname_id ='" & eatid & "' "
						 			
